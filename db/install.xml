<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/cert_fanafesa/db"
       VERSION="2026061801"
       COMMENT="Certificados Fanafesa"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <TABLES>

        <TABLE NAME="local_cert_fanafesa_signers"
               COMMENT="Firmantes para certificados">

            <FIELDS>

                <FIELD NAME="id"
                       TYPE="int"
                       LENGTH="10"
                       NOTNULL="true"
                       SEQUENCE="true"/>

                <FIELD NAME="fullname"
                       TYPE="char"
                       LENGTH="255"
                       NOTNULL="true"/>

                <FIELD NAME="role"
                     TYPE="char"
                     LENGTH="50"
                     NOTNULL="true"/>

                <FIELD NAME="active"
                       TYPE="int"
                       LENGTH="1"
                       NOTNULL="true"
                       DEFAULT="1"/>

                <FIELD NAME="timecreated"
                       TYPE="int"
                       LENGTH="10"
                       NOTNULL="true"/>

                <FIELD NAME="timemodified"
                       TYPE="int"
                       LENGTH="10"
                       NOTNULL="true"/>

            </FIELDS>

            <KEYS>

                <KEY NAME="primary"
                     TYPE="primary"
                     FIELDS="id"/>

            </KEYS>

        </TABLE>

        <TABLE NAME="local_cert_fanafesa_course"
              COMMENT="Configuracion de firmantes por curso">

              <FIELDS>

                     <FIELD NAME="id"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"
                            SEQUENCE="true"/>

                     <FIELD NAME="courseid"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

                     <FIELD NAME="instructorid"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

                     <FIELD NAME="patronid"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

                     <FIELD NAME="trabajadoresid"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

                     <FIELD NAME="usecustombutton"
                            TYPE="int"
                            LENGTH="1"
                            NOTNULL="true"
                            DEFAULT="0"/>

                     <FIELD NAME="timecreated"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

                     <FIELD NAME="timemodified"
                            TYPE="int"
                            LENGTH="10"
                            NOTNULL="true"/>

              </FIELDS>

              <KEYS>

                     <KEY NAME="primary"
                     TYPE="primary"
                     FIELDS="id"/>

              </KEYS>

              </TABLE>

    </TABLES>

</XMLDB>